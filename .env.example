# ──────────────────────────────────────────────────────────────────────────────
# StarfallStore — Root Environment Template
# Copy this to .env and fill in your credentials
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=starfallstore
DB_USERNAME=starfall
DB_PASSWORD=starfall_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── Pusher / Laravel Echo ─────────────────────────────────────────────────────
PUSHER_APP_KEY=your_pusher_app_key
PUSHER_APP_CLUSTER=ap1

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ── Customer Service (Frontend) ──────────────────────────────────────────────
VITE_CS_WHATSAPP_NUMBER=6283874644294
VITE_CS_TELEGRAM_USERNAME=starfall_cs

APP_NAME=StarfallStore
APP_ENV=local
APP_KEY=base64:CHANGE_ME_RUN_PHP_ARTISAN_KEY_GENERATE=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=starfallstore
DB_USERNAME=starfall
DB_PASSWORD=change_me_strong_password

# ── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=redis
BROADCAST_CONNECTION=pusher
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=your_smtp_host
MAIL_PORT=587
MAIL_USERNAME=your_smtp_user
MAIL_PASSWORD=your_smtp_pass
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@starfallstore.com"
MAIL_FROM_NAME="StarfallStore"

# ── Pusher / Laravel Echo ─────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# ── CASHI.ID Payment Gateway ──────────────────────────────────────────────────
CASHI_BASE_URL=https://api.cashi.id/v1
CASHI_MERCHANT_ID=
CASHI_API_KEY=
CASHI_WEBHOOK_SECRET=

# ── Digiflazz H2H ─────────────────────────────────────────────────────────────
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com/v1
DIGIFLAZZ_USERNAME=your_username
DIGIFLAZZ_API_KEY=your_production_key
DIGIFLAZZ_WEBHOOK_SECRET=
DIGIFLAZZ_MODE=development # toggle between 'development' (mock) and 'production' (real API)

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ── WhatsApp (Fonnte API) ─────────────────────────────────────────────────────
FONNTE_BASE_URL=https://api.fonnte.com
FONNTE_TOKEN=
FONNTE_DEVICE=

# ── Sanctum / CORS ────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173
FRONTEND_URL=http://localhost:5173
